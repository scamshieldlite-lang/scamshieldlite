{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "../../",
    "emitDeclarationOnly": false
  },
  "include": [
    "src/**/*",
    "../../packages/shared/scan.ts",
    "../../packages/shared/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "drizzle"]
}
