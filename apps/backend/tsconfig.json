{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Nodenext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"],
      "@scamshieldlite/shared": ["../../packages/shared/scan"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/scan.ts"],
  "exclude": ["node_modules", "dist"]
}
